{
  "name": "lilly",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:dm": "vite --mode dm",
    "dev:lilly": "vite --mode lilly",
    "build": "tsc -b && vite build",
    "build:dm": "tsc -b && vite build --mode dm",
    "build:lilly": "tsc -b && vite build --mode lilly",
    "lint": "oxlint",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "scrape:dm": "node scripts/scrape-dm.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "gh-pages": "^6.3.0",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
